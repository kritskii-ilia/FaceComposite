# Normalize line endings
* text=auto

# Windows batch files — keep CRLF
*.bat text eol=crlf

# Python, JS, HTML, CSS — LF
*.py text eol=lf
*.js text eol=lf
*.html text eol=lf
*.css text eol=lf
*.md text eol=lf
*.json text eol=lf
*.yml text eol=lf

# Binaries
*.ico binary
*.png binary
*.jpg binary
*.zip binary
*.exe binary
